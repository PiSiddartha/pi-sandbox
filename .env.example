# =============================================================================
# Pi Sandbox frontend — copy to .env.local
#   cp .env.example .env.local
# Restart `next dev` after changes. `NEXT_PUBLIC_*` is inlined at build time.
# =============================================================================

# Deployed pi-sandbox-api (HTTP API v2). Must match API Gateway "Invoke URL":
#   https://<api-id>.execute-api.<region>.amazonaws.com/<stage>
# Example dev (stage = api):
NEXT_PUBLIC_SANDBOX_API_URL=test-asd.execute-api.ap-south-1.amazonaws.com/api

# Browser calls (same host + stage as above):
#   GET  {API}/auth/login          → Cognito Hosted UI
#   GET  {API}/auth/callback       → token exchange (add this exact URL in Cognito app client callbacks)
#   GET  {API}/auth/logout
#   GET  {API}/auth/current-user   (Bearer access token)
#   POST {API}/auth/verify-token   (Bearer)
#   POST {API}/request-access
#   GET  {API}/videos?module_slug=…
#   GET  {API}/videos/{id}

# OAuth app client is configured in pi-checkout-infra (`pi_sandbox_cognito_oauth`), not in the frontend.
# The Sandbox app client’s Allowed callback URLs must include (exact match) your API callback, e.g.:
#   test-asd.execute-api.ap-south-1.amazonaws.com/api/auth/callback
# Sign-out URLs must include your site origins (e.g. sandbox.payintelli.com, localhost).

# Tokens: localStorage authToken, idToken, refreshToken (same keys as pi-admin-dashboard).

# Optional: proxy API locally
# NEXT_PUBLIC_SANDBOX_API_URL=http://localhost:3000/api
