# =============================================================================
# Pi Sandbox — copy to .env.local and adjust (Next.js loads .env.local automatically)
#   cp .env.example .env.local
# Restart `next dev` after any change.
# =============================================================================

# Required for Log in / Log out, Request Access form, and video API calls.
# Dev API (ap-south-1): use your deployed pi-sandbox-api execute-api URL + stage `api`.
NEXT_PUBLIC_SANDBOX_API_URL=yourtestapi.execute-api.ap-south-1.amazonaws.com/api

# Local-only: you can point at localhost if you proxy the API, e.g.:
# NEXT_PUBLIC_SANDBOX_API_URL=http://localhost:3000/api
